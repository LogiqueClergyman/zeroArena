{
  "name": "zeroarena-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "npm run build --prefix ../sdk/game && npm run build --prefix ../games/connect4 && npm run build --prefix ../games/sovereign-bluff",
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && node .\\dist\\server.js",
    "test": "npm run build && node --test \"dist/**/*.test.js\"",
    "e2e:game": "npm run build && node dist/scripts/e2e-game.js",
    "e2e:game:real": "npm run build && node dist/scripts/e2e-game-real.js",
    "e2e:game:real:connect4": "npm run build && node dist/scripts/e2e-game-real-connect4.js",
    "test:e2e:real": "npm run build && node --test dist/testing/agents/AgentRunner.real-inference.e2e.test.js",
    "test:e2e:real:connect4": "npm run build && node --test dist/testing/agents/AgentRunner.real-inference.e2e.test.js",
    "upload:rulebook": "npm run build && node dist/scripts/upload-rulebook.js",
    "upload:rulebook:connect4": "npm run build && node dist/scripts/upload-rulebook.js connect4",
    "setup:compute": "npm run build && node dist/scripts/setup-compute-ledgers.js"
  },
  "dependencies": {
    "@zeroarena/game-connect4": "file:../games/connect4",
    "@zeroarena/game-sdk": "file:../sdk/game",
    "@zeroarena/game-sovereign-bluff": "file:../games/sovereign-bluff",
    "@0gfoundation/0g-compute-ts-sdk": "^0.8.4",
    "@0gfoundation/0g-storage-ts-sdk": "^1.2.10",
    "@fastify/cors": "^11.2.0",
    "ajv": "^8.20.0",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.1",
    "fastify": "^5.8.5"
  }
}
