# ZeroArena judged-demo environment.
# Copy to a local untracked file or set these in your shell.
# Do not commit real private keys or API keys.

# General
PORT=3001
LOCAL_DEV_ALLOW_MOCKS=false
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# 0G Galileo EVM
EVM_CHAIN_ID=16602
EVM_RPC_URL=https://evmrpc-testnet.0g.ai
ZERO_G_EVM_RPC_URL=https://evmrpc-testnet.0g.ai
EVM_PRIVATE_KEY=
DEPLOYER_ADDRESS=

# Prize pool
PAYOUT_MODE=contract
PRIZE_POOL_ADDRESS=
MATCH_STAKE_WEI=1000000000000000

# 0G Storage
ARCHIVE_MODE=0g
ZERO_G_STORAGE_RPC=https://evmrpc-testnet.0g.ai
ZERO_G_STORAGE_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
ZERO_G_STORAGE_PRIVATE_KEY=
SOVEREIGN_BLUFF_RULEBOOK_HASH=
SOVEREIGN_BLUFF_RULEBOOK_URL=
SOVEREIGN_BLUFF_RULEBOOK_VERSION=1.0.0

# Agent wallets
AGENT_ALPHA_WALLET_ADDRESS=
AGENT_ALPHA_PRIVATE_KEY=
AGENT_BETA_WALLET_ADDRESS=
AGENT_BETA_PRIVATE_KEY=

# 0G Compute mode.
# Current implementation uses Direct SDK when AGENT_INFERENCE_MODE=0g-serving.
AGENT_INFERENCE_MODE=0g-serving
ZERO_G_PROVIDER_ADDRESS=
ZERO_G_SERVING_MODEL=
ZERO_G_AUTO_FUND_BUFFER_MULTIPLIER=1
# Current observed testnet provider limit is 10 requests/min. 7000ms keeps the shared two-agent runner below it.
ZERO_G_INFERENCE_REQUEST_SPACING_MS=7000
ZERO_G_INFERENCE_TEMPERATURE=0.85
ZERO_G_INFERENCE_TOP_P=0.9
# Direct SDK creates a 0G Compute ledger per agent wallet. The SDK minimum for a new ledger is 3 0G.
ZERO_G_COMPUTE_LEDGER_CREATE_AMOUNT=3

# Optional Router values if Session E switches from Direct SDK to Router.
# Router uses API keys and a separate Router/Payment Layer balance.
ZERO_G_ROUTER_BASE_URL=https://router-api-testnet.integratenetwork.work/v1
ZERO_G_ROUTER_MODEL=zai-org/GLM-5-FP8
AGENT_ALPHA_ZERO_G_ROUTER_API_KEY=
AGENT_BETA_ZERO_G_ROUTER_API_KEY=
ZERO_G_ROUTER_MANAGEMENT_KEY=

# Frontend
VITE_BACKEND_URL=http://localhost:3001
