{
  "name": "@zeroarena/operator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "zeroarena-operator": "dist/server.js"
  },
  "scripts": {
    "build:server": "npm run build --prefix ../sdk/agent && tsc -p tsconfig.json",
    "build": "npm run build:server && npm run build --prefix web",
    "dev": "npm run build && node dist/server.js",
    "dev:all": "node scripts/dev-all.mjs",
    "dev:api": "npm run build:server && node dist/server.js",
    "start": "node dist/server.js",
    "test": "npm run build --prefix ../sdk/agent && tsc -p tsconfig.json && node --test \"dist/**/*.test.js\""
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^8.2.0",
    "fastify": "^5.8.5",
    "zeroarena": "file:.."
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5"
  }
}
